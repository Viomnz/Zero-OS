                <Button Height="38" Margin="0,0,8,8" Content="Zero AI Simulate Self Update" Click="ZeroAiContinuitySimulate_Click" />
                <Button Height="38" Margin="0,0,8,8" Content="Zero AI Apply Safe Simulated Update" Click="ZeroAiContinuitySimulateApply_Click" />
