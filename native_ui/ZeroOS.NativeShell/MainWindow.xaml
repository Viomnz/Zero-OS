<Window x:Class="ZeroOS.NativeShell.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Zero OS Native Shell"
        Width="1220"
        Height="820"
        Closing="Window_Closing"
        Background="{StaticResource WindowBg}">
  <Grid Margin="18">
    <Grid.RowDefinitions>
      <RowDefinition Height="Auto" />
      <RowDefinition Height="*" />
    </Grid.RowDefinitions>

    <Border Grid.Row="0" Background="{StaticResource HeroBg}" CornerRadius="18" Padding="20" Margin="0,0,0,16">
      <StackPanel>
        <TextBlock Text="Zero OS Native Shell" FontSize="28" FontWeight="Bold" Foreground="{StaticResource TextFg}" />
        <TextBlock Text="Production-grade Windows shell scaffold for sharing, releasing, and managing Zero OS."
                   Margin="0,8,0,0"
                   FontSize="13"
                   Foreground="{StaticResource MutedFg}" />
      </StackPanel>
    </Border>

    <Grid Grid.Row="1">
      <Grid.RowDefinitions>
        <RowDefinition Height="Auto" />
        <RowDefinition Height="*" />
      </Grid.RowDefinitions>

      <Border Grid.Row="0" Background="{StaticResource PanelBg}" CornerRadius="16" Padding="14" Margin="0,0,0,14">
        <TextBlock x:Name="StatusText"
                   Text="Ready"
                   Foreground="{StaticResource MutedFg}"
                   TextWrapping="Wrap" />
      </Border>

      <TabControl Grid.Row="1" Background="{StaticResource PanelBg}" BorderThickness="0">
        <TabItem Header="Quick Start">
          <Grid Margin="12">
            <Grid.ColumnDefinitions>
              <ColumnDefinition Width="1.2*" />
              <ColumnDefinition Width="1.8*" />
            </Grid.ColumnDefinitions>
            <Border Grid.Column="0" Background="{StaticResource PanelBg}" CornerRadius="16" Padding="16" Margin="0,0,10,0">
              <StackPanel>
                <TextBlock Text="Quick Start Wizard" FontSize="18" FontWeight="Bold" Foreground="{StaticResource TextFg}" />
                <TextBlock Text="Follow these steps in order. GitHub users should be able to finish setup without learning commands."
                           Margin="0,6,0,16"
                           TextWrapping="Wrap"
                           Foreground="{StaticResource MutedFg}" />
                <Button Height="42" Margin="0,0,0,8" Content="Download Native App" Click="OpenReleases_Click" />
                <Button Height="42" Margin="0,0,0,8" Content="Step 1. Open Repository" Click="OpenRepository_Click" />
                <Button Height="42" Margin="0,0,0,8" Content="Step 2. Run First-Run" Click="RunFirstRun_Click" />
                <Button Height="42" Margin="0,0,0,8" Content="Step 3. Open Shell UI" Click="OpenShellUi_Click" />
                <Button Height="42" Margin="0,0,0,8" Content="Step 4. Install + Start Background Agent" Click="QuickStartInstallBackgroundAgent_Click" />
                <Button Height="42" Margin="0,0,0,8" Content="Step 5. Know Everything" Click="KnowEverything_Click" />
                <Button Height="42" Margin="0,0,0,12" Content="Step 6. Complete All" Click="KnowEverythingCompleteAll_Click" />
                <Button Height="38" Content="Refresh Wizard Status" Click="RefreshQuickStart_Click" />
              </StackPanel>
            </Border>
            <Border Grid.Column="1" Background="{StaticResource PanelBg}" CornerRadius="16" Padding="16" Margin="10,0,0,0">
              <DockPanel>
                <TextBlock DockPanel.Dock="Top"
                           Text="Wizard Status"
                           FontSize="18"
                           FontWeight="Bold"
                           Foreground="{StaticResource TextFg}" />
                <TextBox x:Name="QuickStartStatusBox"
                         Margin="0,12,0,0"
                         AcceptsReturn="True"
                         VerticalScrollBarVisibility="Auto"
                         HorizontalScrollBarVisibility="Auto"
                         TextWrapping="Wrap"
                         Background="#0D1826"
                         Foreground="{StaticResource TextFg}"
                         BorderThickness="0"
                         IsReadOnly="True"
                         Text="Loading quick start status..." />
              </DockPanel>
            </Border>
          </Grid>
        </TabItem>
        <TabItem Header="Share">
          <Grid Margin="12">
            <Grid.ColumnDefinitions>
              <ColumnDefinition Width="2*" />
              <ColumnDefinition Width="3*" />
            </Grid.ColumnDefinitions>
            <Border Grid.Column="0" Background="{StaticResource PanelBg}" CornerRadius="16" Padding="16" Margin="0,0,10,0">
              <StackPanel>
                <TextBlock Text="Start Here" FontSize="18" FontWeight="Bold" Foreground="{StaticResource TextFg}" />
                <TextBlock Text="GitHub users should not need to know Zero OS commands. Use these buttons in order."
                           Margin="0,6,0,16"
                           TextWrapping="Wrap"
                           Foreground="{StaticResource MutedFg}" />
                <Button Height="42" Margin="0,0,0,8" Content="Download Native App" Click="OpenReleases_Click" />
                <Button Height="42" Margin="0,0,0,8" Content="1. Open Repository" Click="OpenRepository_Click" />
                <Button Height="42" Margin="0,0,0,8" Content="2. Run First-Run" Click="RunFirstRun_Click" />
                <Button Height="42" Margin="0,0,0,8" Content="3. Open Shell UI" Click="OpenShellUi_Click" />
                <Button Height="42" Margin="0,0,0,8" Content="4. Install + Start Background Agent" Click="QuickStartInstallBackgroundAgent_Click" />
                <Button Height="42" Margin="0,0,0,12" Content="5. Know Everything + Complete All" Click="KnowEverythingCompleteAll_Click" />
                <TextBlock Text="More Actions"
                           Margin="0,4,0,10"
                           FontSize="16"
                           FontWeight="Bold"
                           Foreground="{StaticResource TextFg}" />
                <Button Height="38" Margin="0,0,0,8" Content="Copy Clone Command" Click="CopyCloneCommand_Click" />
                <Button Height="38" Margin="0,0,0,8" Content="Open Releases" Click="OpenReleases_Click" />
                <Button Height="38" Margin="0,0,0,8" Content="Open Installer Folder" Click="OpenNativeInstallerFolder_Click" />
                <Button Height="38" Margin="0,0,0,8" Content="Export Bundle" Click="ExportBundle_Click" />
                <Button Height="38" Margin="0,0,0,8" Content="Create Share Zip" Click="CreateShareZip_Click" />
                <Button Height="38" Content="Open Dist Folder" Click="OpenDist_Click" />
              </StackPanel>
            </Border>
            <Border Grid.Column="1" Background="{StaticResource PanelBg}" CornerRadius="16" Padding="16" Margin="10,0,0,0">
              <DockPanel>
                <TextBlock DockPanel.Dock="Top"
                           Text="Output"
                           FontSize="18"
                           FontWeight="Bold"
                           Foreground="{StaticResource TextFg}" />
                <TextBox x:Name="OutputBox"
                         Margin="0,12,0,0"
                         AcceptsReturn="True"
                         VerticalScrollBarVisibility="Auto"
                         HorizontalScrollBarVisibility="Auto"
                         TextWrapping="Wrap"
                         Background="#0D1826"
                         Foreground="{StaticResource TextFg}"
                         BorderThickness="0"
                         IsReadOnly="True"
                         Text="Start Here&#x0a;1. Download Native App or clone Zero OS&#x0a;2. Run First-Run&#x0a;3. Open Shell UI&#x0a;4. Install + Start Background Agent&#x0a;5. Use the built-in buttons&#x0a;&#x0a;GitHub users should not need to learn commands." />
              </DockPanel>
            </Border>
          </Grid>
        </TabItem>

        <TabItem Header="System Health">
          <Grid Margin="12">
            <Grid.ColumnDefinitions>
              <ColumnDefinition Width="1.1*" />
              <ColumnDefinition Width="1.9*" />
            </Grid.ColumnDefinitions>
            <Border Grid.Column="0" Background="{StaticResource PanelBg}" CornerRadius="16" Padding="16" Margin="0,0,10,0">
              <StackPanel>
                <TextBlock Text="System Health"
                           FontSize="18"
                           FontWeight="Bold"
                           Foreground="{StaticResource TextFg}" />
                <TextBlock Text="One place to answer: is Zero OS okay right now?"
                           Margin="0,6,0,16"
                           TextWrapping="Wrap"
                           Foreground="{StaticResource MutedFg}" />
                <Button Height="42" Margin="0,0,0,8" Content="Refresh System Health" Click="RefreshSystemHealth_Click" />
                <Button Height="42" Margin="0,0,0,8" Content="Fix Now" Click="FixSystemHealthNow_Click" />
                <Button Height="42" Margin="0,0,0,8" Content="Start Background Agent" Click="ZeroAiRuntimeAgentStart_Click" />
                <Button Height="42" Margin="0,0,0,8" Content="Run Runtime Now" Click="ZeroAiRuntimeRun_Click" />
                <Button Height="42" Margin="0,0,0,12" Content="Repair Continuity" Click="ZeroAiSelfRepairRestoreContinuity_Click" />
                <TextBlock Text="Fast path"
                           Margin="0,4,0,10"
                           FontSize="16"
                           FontWeight="Bold"
                           Foreground="{StaticResource TextFg}" />
                <Button Height="38" Margin="0,0,0,8" Content="Install + Start Background Agent" Click="QuickStartInstallBackgroundAgent_Click" />
                <Button Height="38" Content="Open Runtime Tab Actions" Click="ZeroAiRuntimeStatus_Click" />
              </StackPanel>
            </Border>
            <Border Grid.Column="1" Background="{StaticResource PanelBg}" CornerRadius="16" Padding="16" Margin="10,0,0,0">
              <DockPanel>
                <TextBlock DockPanel.Dock="Top"
                           Text="Health Summary"
                           FontSize="18"
                           FontWeight="Bold"
                           Foreground="{StaticResource TextFg}" />
                <TextBox x:Name="SystemHealthBox"
                         Margin="0,12,0,0"
                         AcceptsReturn="True"
                         VerticalScrollBarVisibility="Auto"
                         HorizontalScrollBarVisibility="Auto"
                         TextWrapping="Wrap"
                         Background="#0D1826"
                         Foreground="{StaticResource TextFg}"
                         BorderThickness="0"
                         IsReadOnly="True"
                         Text="Loading system health..." />
              </DockPanel>
            </Border>
          </Grid>
        </TabItem>

        <TabItem Header="Autonomy">
          <Grid Margin="12">
            <Grid.ColumnDefinitions>
              <ColumnDefinition Width="1.1*" />
              <ColumnDefinition Width="1.9*" />
            </Grid.ColumnDefinitions>
            <Border Grid.Column="0" Background="{StaticResource PanelBg}" CornerRadius="16" Padding="16" Margin="0,0,10,0">
              <StackPanel>
                <TextBlock Text="Autonomy"
                           FontSize="18"
                           FontWeight="Bold"
                           Foreground="{StaticResource TextFg}" />
                <TextBlock Text="See Zero AI's current goal, next action, blocked reasons, and autonomous loop state."
                           Margin="0,6,0,16"
                           TextWrapping="Wrap"
                           Foreground="{StaticResource MutedFg}" />
                <Button Height="42" Margin="0,0,0,8" Content="Refresh Autonomy" Click="RefreshAutonomy_Click" />
                <Button Height="42" Margin="0,0,0,8" Content="Sync Goals" Click="ZeroAiAutonomySync_Click" />
                <Button Height="42" Margin="0,0,0,8" Content="Run Autonomous Work" Click="ZeroAiAutonomyRun_Click" />
                <Button Height="42" Margin="0,0,0,8" Content="Autonomy Loop On" Click="ZeroAiAutonomyLoopOn_Click" />
                <Button Height="42" Margin="0,0,0,8" Content="Autonomy Loop Tick" Click="ZeroAiAutonomyLoopTick_Click" />
                <Button Height="42" Margin="0,0,0,12" Content="Autonomy Loop Off" Click="ZeroAiAutonomyLoopOff_Click" />
                <Button Height="38" Margin="0,0,0,8" Content="Evolution Status" Click="ZeroAiEvolutionStatus_Click" />
                <Button Height="38" Margin="0,0,0,8" Content="Evolution Auto Run" Click="ZeroAiEvolutionAutoRun_Click" />
                <Button Height="38" Margin="0,0,0,8" Content="Evolution Rollback" Click="ZeroAiEvolutionRollback_Click" />
                <Button Height="38" Margin="0,0,0,8" Content="Source Evolution Status" Click="ZeroAiSourceEvolutionStatus_Click" />
                <Button Height="38" Margin="0,0,0,8" Content="Source Evolution Auto Run" Click="ZeroAiSourceEvolutionAutoRun_Click" />
                <Button Height="38" Margin="0,0,0,12" Content="Source Evolution Rollback" Click="ZeroAiSourceEvolutionRollback_Click" />
                <TextBlock Text="Fast path"
                           Margin="0,4,0,10"
                           FontSize="16"
                           FontWeight="Bold"
                           Foreground="{StaticResource TextFg}" />
                <Button Height="38" Margin="0,0,0,8" Content="Fix Now" Click="FixSystemHealthNow_Click" />
                <Button Height="38" Margin="0,0,0,8" Content="Run Runtime Now" Click="ZeroAiRuntimeRun_Click" />
                <Button Height="38" Content="Start Background Agent" Click="ZeroAiRuntimeAgentStart_Click" />
              </StackPanel>
            </Border>
            <Border Grid.Column="1" Background="{StaticResource PanelBg}" CornerRadius="16" Padding="16" Margin="10,0,0,0">
              <DockPanel>
                <TextBlock DockPanel.Dock="Top"
                           Text="Autonomy Summary"
                           FontSize="18"
                           FontWeight="Bold"
                           Foreground="{StaticResource TextFg}" />
                <TextBox x:Name="AutonomyBox"
                         Margin="0,12,0,0"
                         AcceptsReturn="True"
                         VerticalScrollBarVisibility="Auto"
                         HorizontalScrollBarVisibility="Auto"
                         TextWrapping="Wrap"
                         Background="#0D1826"
                         Foreground="{StaticResource TextFg}"
                         BorderThickness="0"
                         IsReadOnly="True"
                         Text="Loading autonomy status..." />
              </DockPanel>
            </Border>
          </Grid>
        </TabItem>

        <TabItem Header="Zero Control">
            <Grid Margin="12">
            <Grid.ColumnDefinitions>
              <ColumnDefinition Width="1.1*" />
              <ColumnDefinition Width="1.9*" />
            </Grid.ColumnDefinitions>
            <Border Grid.Column="0" Background="{StaticResource PanelBg}" CornerRadius="16" Padding="16" Margin="0,0,10,0">
              <StackPanel>
                <TextBlock Text="Zero Control"
                           FontSize="18"
                           FontWeight="Bold"
                           Foreground="{StaticResource TextFg}" />
                <TextBlock Text="See the highest-value next steps, subsystem contracts, and tool gaps without typing commands."
                           Margin="0,6,0,16"
                           TextWrapping="Wrap"
                           Foreground="{StaticResource MutedFg}" />
                <Button Height="42" Margin="0,0,0,8" Content="Refresh Control Map" Click="RefreshControlMap_Click" />
                <Button Height="42" Margin="0,0,0,8" Content="Run Zero AI Next" Click="ZeroAiNext_Click" />
                <Button Height="42" Margin="0,0,0,8" Content="Refresh Tool Registry" Click="ZeroAiToolsStatus_Click" />
                <Button Height="42" Margin="0,0,0,8" Content="Refresh Capability Map" Click="ZeroAiCapabilityMapStatus_Click" />
                <Button Height="42" Margin="0,0,0,8" Content="Refresh Control Workflows" Click="ZeroAiControlWorkflowsStatus_Click" />
                <Button Height="42" Margin="0,0,0,8" Content="Refresh Benchmark Dashboard" Click="ZeroAiBenchmarkDashboardRefresh_Click" />
                <Button Height="42" Margin="0,0,0,8" Content="Refresh Benchmark Alerts" Click="ZeroAiBenchmarkAlertsRefresh_Click" />
                <Button Height="42" Margin="0,0,0,8" Content="Refresh Benchmark Remediation" Click="ZeroAiBenchmarkRemediationRefresh_Click" />
                <Button Height="42" Margin="0,0,0,8" Content="Request Benchmark Remediation Approval" Click="ZeroAiBenchmarkRemediationRequest_Click" />
                <Button Height="42" Margin="0,0,0,8" Content="Approve Pending Remediation" Click="ZeroAiBenchmarkRemediationApprove_Click" />
                <Button Height="42" Margin="0,0,0,8" Content="Reject Pending Remediation" Click="ZeroAiBenchmarkRemediationReject_Click" />
                <Button Height="42" Margin="0,0,0,12" Content="Execute Approved Remediation" Click="ZeroAiBenchmarkRemediationExecute_Click" />
                <TextBlock Text="Fast path"
                           Margin="0,4,0,10"
                           FontSize="16"
                           FontWeight="Bold"
                           Foreground="{StaticResource TextFg}" />
                <Button Height="38" Margin="0,0,0,8" Content="Start Background Agent" Click="ZeroAiRuntimeAgentStart_Click" />
                <Button Height="38" Margin="0,0,0,8" Content="Run Runtime Now" Click="ZeroAiRuntimeRun_Click" />
                <Button Height="38" Content="Open Shell UI" Click="OpenShellUi_Click" />
              </StackPanel>
            </Border>
            <Border Grid.Column="1" Background="{StaticResource PanelBg}" CornerRadius="16" Padding="16" Margin="10,0,0,0">
              <DockPanel>
                <TextBlock DockPanel.Dock="Top"
                           Text="Control Summary"
                           FontSize="18"
                           FontWeight="Bold"
                           Foreground="{StaticResource TextFg}" />
                <TextBox x:Name="ControlMapBox"
                         Margin="0,12,0,0"
                         AcceptsReturn="True"
                         VerticalScrollBarVisibility="Auto"
                         HorizontalScrollBarVisibility="Auto"
                         TextWrapping="Wrap"
                         Background="#0D1826"
                         Foreground="{StaticResource TextFg}"
                         BorderThickness="0"
                         IsReadOnly="True"
                         Text="Loading control map..." />
              </DockPanel>
            </Border>
            </Grid>
        </TabItem>

        <TabItem Header="Local Mods">
          <Grid Margin="12">
            <Grid.ColumnDefinitions>
              <ColumnDefinition Width="1.15*" />
              <ColumnDefinition Width="1.85*" />
            </Grid.ColumnDefinitions>
            <Border Grid.Column="0" Background="{StaticResource PanelBg}" CornerRadius="16" Padding="16" Margin="0,0,10,0">
              <ScrollViewer VerticalScrollBarVisibility="Auto">
                <StackPanel>
                  <TextBlock Text="Private Local Mods"
                             FontSize="18"
                             FontWeight="Bold"
                             Foreground="{StaticResource TextFg}" />
                  <TextBlock Text="Install and manage private-local Zero OS modifications without editing the shared core."
                             Margin="0,6,0,16"
                             TextWrapping="Wrap"
                             Foreground="{StaticResource MutedFg}" />

                  <TextBlock Text="Local mod path"
                             FontSize="15"
                             FontWeight="Bold"
                             Foreground="{StaticResource TextFg}" />
                  <TextBox x:Name="LocalModPathBox"
                           Margin="0,8,0,8"
                           Height="36"
                           Padding="10,6"
                           Background="#0D1826"
                           Foreground="{StaticResource TextFg}"
                           BorderThickness="0"
                           Text="plugins" />
                  <Button Height="38" Margin="0,0,0,8" Content="Browse Mod File" Click="BrowseLocalModFile_Click" />
                  <Button Height="38" Margin="0,0,0,8" Content="Browse Mod Folder" Click="BrowseLocalModFolder_Click" />
                  <Button Height="42" Margin="0,0,0,12" Content="Install Local Mod Path" Click="InstallLocalModPath_Click" />

                  <TextBlock Text="Plugin name"
                             FontSize="15"
                             FontWeight="Bold"
                             Foreground="{StaticResource TextFg}" />
                  <TextBox x:Name="LocalModNameBox"
                           Margin="0,8,0,8"
                           Height="36"
                           Padding="10,6"
                           Background="#0D1826"
                           Foreground="{StaticResource TextFg}"
                           BorderThickness="0"
                           Text="" />
                  <Button Height="38" Margin="0,0,0,8" Content="Scaffold New Local Mod" Click="ScaffoldLocalMod_Click" />
                  <Button Height="38" Margin="0,0,0,8" Content="Enable Selected Mod" Click="EnableLocalMod_Click" />
                  <Button Height="38" Margin="0,0,0,8" Content="Disable Selected Mod" Click="DisableLocalMod_Click" />
                  <Button Height="38" Margin="0,0,0,8" Content="Verify Selected Mod" Click="VerifyLocalMod_Click" />
                  <Button Height="38" Margin="0,0,0,8" Content="Sign Selected Mod" Click="SignLocalMod_Click" />
                  <Button Height="38" Margin="0,0,0,8" Content="Refresh Local Mods" Click="RefreshLocalMods_Click" />
                  <Button Height="38" Content="Open Plugins Folder" Click="OpenPluginsFolder_Click" />
                </StackPanel>
              </ScrollViewer>
            </Border>
            <Border Grid.Column="1" Background="{StaticResource PanelBg}" CornerRadius="16" Padding="16" Margin="10,0,0,0">
              <DockPanel>
                <TextBlock DockPanel.Dock="Top"
                           Text="Local Mods Summary"
                           FontSize="18"
                           FontWeight="Bold"
                           Foreground="{StaticResource TextFg}" />
                <TextBox x:Name="LocalModsBox"
                         Margin="0,12,0,0"
                         AcceptsReturn="True"
                         VerticalScrollBarVisibility="Auto"
                         HorizontalScrollBarVisibility="Auto"
                         TextWrapping="Wrap"
                         Background="#0D1826"
                         Foreground="{StaticResource TextFg}"
                         BorderThickness="0"
                         IsReadOnly="True"
                         Text="Loading local mods..." />
              </DockPanel>
            </Border>
          </Grid>
        </TabItem>

        <TabItem Header="Artifacts">
            <Grid Margin="12">
            <Grid.ColumnDefinitions>
              <ColumnDefinition Width="1.2*" />
              <ColumnDefinition Width="1.8*" />
            </Grid.ColumnDefinitions>
            <Border Grid.Column="0" Background="{StaticResource PanelBg}" CornerRadius="16" Padding="16" Margin="0,0,10,0">
              <StackPanel>
                <TextBlock Text="Artifacts"
                           FontSize="18"
                           FontWeight="Bold"
                           Foreground="{StaticResource TextFg}" />
                <ListBox x:Name="ArtifactsListBox"
                         Margin="0,12,0,0"
                         SelectionChanged="ArtifactsListBox_SelectionChanged"
                         Background="#0D1826"
                         Foreground="{StaticResource TextFg}"
                         BorderThickness="0" />
              </StackPanel>
            </Border>
            <Border Grid.Column="1" Background="{StaticResource PanelBg}" CornerRadius="16" Padding="16" Margin="10,0,0,0">
              <DockPanel>
                <StackPanel DockPanel.Dock="Top" Orientation="Horizontal">
                  <TextBlock Text="Artifact Details"
                             FontSize="18"
                             FontWeight="Bold"
                             Foreground="{StaticResource TextFg}" />
                  <Button Margin="12,0,0,0" Padding="10,4" Content="Refresh" Click="RefreshArtifacts_Click" />
                  <Button Margin="8,0,0,0" Padding="10,4" Content="Open" Click="OpenArtifact_Click" />
                  <Button Margin="8,0,0,0" Padding="10,4" Content="Reveal" Click="RevealArtifact_Click" />
                  <Button Margin="8,0,0,0" Padding="10,4" Content="Copy Path" Click="CopyArtifactPath_Click" />
                </StackPanel>
                <TextBox x:Name="ArtifactDetailsBox"
                         Margin="0,12,0,0"
                         AcceptsReturn="True"
                         VerticalScrollBarVisibility="Auto"
                         HorizontalScrollBarVisibility="Auto"
                         TextWrapping="Wrap"
                         Background="#0D1826"
                         Foreground="{StaticResource TextFg}"
                         BorderThickness="0"
                         IsReadOnly="True"
                         Text="No artifact selected." />
              </DockPanel>
            </Border>
          </Grid>
        </TabItem>

        <TabItem Header="Code Index">
          <Grid Margin="12">
            <Grid.ColumnDefinitions>
              <ColumnDefinition Width="1.1*" />
              <ColumnDefinition Width="1.9*" />
            </Grid.ColumnDefinitions>
            <Border Grid.Column="0" Background="{StaticResource PanelBg}" CornerRadius="16" Padding="16" Margin="0,0,10,0">
              <StackPanel>
                <TextBlock Text="Large Code Index" FontSize="18" FontWeight="Bold" Foreground="{StaticResource TextFg}" />
                <TextBlock Text="Index large workspaces and search code or symbols without reading the whole tree every time."
                           Margin="0,6,0,16"
                           TextWrapping="Wrap"
                           Foreground="{StaticResource MutedFg}" />
                <Button Height="40" Margin="0,0,0,8" Content="Index Workspace" Click="IndexWorkspace_Click" />
                <Button Height="40" Margin="0,0,0,8" Content="Refresh Index Status" Click="RefreshCodeIndex_Click" />
                <Button Height="38" Margin="0,0,0,8" Content="Watch On" Click="WatchCodeIndexOn_Click" />
                <Button Height="38" Margin="0,0,0,8" Content="Watch Tick" Click="WatchCodeIndexTick_Click" />
                <Button Height="38" Margin="0,0,0,8" Content="Watch Status" Click="WatchCodeIndexStatus_Click" />
                <Button Height="38" Margin="0,0,0,8" Content="Watch Off" Click="WatchCodeIndexOff_Click" />
                <TextBox x:Name="CodeSearchBox"
                         Margin="0,8,0,8"
                         Padding="10,6"
                         Background="#0D1826"
                         Foreground="{StaticResource TextFg}"
                         BorderThickness="0"
                         Text="native shell" />
                <Button Height="38" Margin="0,0,0,8" Content="Search Code" Click="SearchCodeIndex_Click" />
                <Button Height="38" Content="Search Symbols" Click="SearchSymbols_Click" />
              </StackPanel>
            </Border>
            <Border Grid.Column="1" Background="{StaticResource PanelBg}" CornerRadius="16" Padding="16" Margin="10,0,0,0">
              <DockPanel>
                <TextBlock DockPanel.Dock="Top"
                           Text="Index Output"
                           FontSize="18"
                           FontWeight="Bold"
                           Foreground="{StaticResource TextFg}" />
                <TextBox x:Name="CodeIndexBox"
                         Margin="0,12,0,0"
                         AcceptsReturn="True"
                         VerticalScrollBarVisibility="Auto"
                         HorizontalScrollBarVisibility="Auto"
                         TextWrapping="Wrap"
                         Background="#0D1826"
                         Foreground="{StaticResource TextFg}"
                         BorderThickness="0"
                         IsReadOnly="True"
                         Text="Loading large code index status..." />
              </DockPanel>
            </Border>
          </Grid>
        </TabItem>

        <TabItem Header="Files">
          <Grid Margin="12">
            <Grid.ColumnDefinitions>
              <ColumnDefinition Width="1.1*" />
              <ColumnDefinition Width="1.9*" />
            </Grid.ColumnDefinitions>
            <Border Grid.Column="0" Background="{StaticResource PanelBg}" CornerRadius="16" Padding="16" Margin="0,0,10,0">
              <DockPanel>
                <Grid DockPanel.Dock="Top">
                  <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                  </Grid.RowDefinitions>
                  <StackPanel Grid.Row="0" Orientation="Horizontal">
                    <TextBlock Text="Workspace Files"
                               FontSize="18"
                               FontWeight="Bold"
                               Foreground="{StaticResource TextFg}" />
                    <Button Margin="12,0,0,0" Padding="10,4" Content="Refresh" Click="RefreshFiles_Click" />
                  </StackPanel>
                  <StackPanel Grid.Row="1" Orientation="Horizontal" Margin="0,12,0,12">
                    <TextBox x:Name="WorkspaceSearchBox"
                             Width="260"
                             Padding="10,6"
                             Background="#0D1826"
                             Foreground="{StaticResource TextFg}"
                             BorderThickness="0"
                             Text=""/>
                    <Button Margin="8,0,0,0" Padding="12,6" Content="Search" Click="SearchWorkspace_Click" />
                    <Button Margin="8,0,0,0" Padding="12,6" Content="Clear" Click="ClearWorkspaceSearch_Click" />
                  </StackPanel>
                  <TabControl Grid.Row="2" Background="{StaticResource PanelBg}" BorderThickness="0">
                    <TabItem Header="Tree">
                      <TreeView x:Name="WorkspaceTreeView"
                                Margin="0,8,0,0"
                                SelectedItemChanged="WorkspaceTreeView_SelectedItemChanged"
                                Background="#0D1826"
                                Foreground="{StaticResource TextFg}"
                                BorderThickness="0" />
                    </TabItem>
                    <TabItem Header="Search Results">
                      <ListBox x:Name="WorkspaceSearchResultsListBox"
                               Margin="0,8,0,0"
                               SelectionChanged="WorkspaceSearchResultsListBox_SelectionChanged"
                               Background="#0D1826"
                               Foreground="{StaticResource TextFg}"
                               BorderThickness="0" />
                    </TabItem>
                  </TabControl>
                </Grid>
              </DockPanel>
            </Border>
            <Border Grid.Column="1" Background="{StaticResource PanelBg}" CornerRadius="16" Padding="16" Margin="10,0,0,0">
              <DockPanel>
                <StackPanel DockPanel.Dock="Top" Orientation="Horizontal">
                  <TextBlock Text="File Viewer"
                             FontSize="18"
                             FontWeight="Bold"
                             Foreground="{StaticResource TextFg}" />
                  <Button Margin="12,0,0,0" Padding="10,4" Content="Save" Click="SaveWorkspaceFile_Click" />
                  <Button Margin="8,0,0,0" Padding="10,4" Content="New File" Click="NewWorkspaceFile_Click" />
                  <Button Margin="8,0,0,0" Padding="10,4" Content="New Folder" Click="NewWorkspaceFolder_Click" />
                  <Button Margin="8,0,0,0" Padding="10,4" Content="Rename" Click="RenameWorkspacePath_Click" />
                  <Button Margin="8,0,0,0" Padding="10,4" Content="Delete" Click="DeleteWorkspacePath_Click" />
                  <Button Margin="12,0,0,0" Padding="10,4" Content="Open Externally" Click="OpenWorkspacePath_Click" />
                  <Button Margin="8,0,0,0" Padding="10,4" Content="Reveal" Click="RevealWorkspacePath_Click" />
                  <Button Margin="8,0,0,0" Padding="10,4" Content="Copy Path" Click="CopyWorkspacePath_Click" />
                </StackPanel>
                <TextBlock x:Name="WorkspaceEditorStatusText"
                           Margin="0,10,0,0"
                           Foreground="{StaticResource MutedFg}"
                           Text="Text files can be edited here and saved back into the Zero OS workspace." />
                <TextBox x:Name="WorkspaceFileBox"
                         Margin="0,12,0,0"
                         AcceptsReturn="True"
                         TextChanged="WorkspaceFileBox_TextChanged"
                         VerticalScrollBarVisibility="Auto"
                         HorizontalScrollBarVisibility="Auto"
                         TextWrapping="Wrap"
                         Background="#0D1826"
                         Foreground="{StaticResource TextFg}"
                         BorderThickness="0"
                         IsReadOnly="False"
                         Text="Select a file or folder from the Zero OS workspace." />
              </DockPanel>
            </Border>
          </Grid>
        </TabItem>

        <TabItem Header="Releases">
          <Border Margin="12" Background="{StaticResource PanelBg}" CornerRadius="16" Padding="16">
            <Grid>
              <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
              </Grid.RowDefinitions>
              <StackPanel>
              <TextBlock Text="Release Manager" FontSize="18" FontWeight="Bold" Foreground="{StaticResource TextFg}" />
              <TextBlock Text="Prepare release links, portable installers, and Windows-native packages for GitHub users."
                         Margin="0,6,0,16"
                         Foreground="{StaticResource MutedFg}" />
              <WrapPanel>
                <Button Height="38" Margin="0,0,8,8" Content="Download Native App" Click="OpenReleases_Click" />
                <Button Height="38" Margin="0,0,8,8" Content="Open Releases" Click="OpenReleases_Click" />
                <Button Height="38" Margin="0,0,8,8" Content="Copy Clone Command" Click="CopyCloneCommand_Click" />
                <Button Height="38" Margin="0,0,8,8" Content="Create Share Zip" Click="CreateShareZip_Click" />
                <Button Height="38" Margin="0,0,8,8" Content="Copy Publish Command" Click="CopyPublishCommand_Click" />
                <Button Height="38" Margin="0,0,8,8" Content="Copy MSIX Command" Click="CopyMsixCommand_Click" />
                <Button Height="38" Margin="0,0,8,8" Content="Build Native Publish" Click="BuildNativePublish_Click" />
                <Button Height="38" Margin="0,0,8,8" Content="Create Portable Installer" Click="CreatePortableInstaller_Click" />
                <Button Height="38" Margin="0,0,8,8" Content="Create MSIX Scaffold" Click="CreateNativeMsix_Click" />
                <Button Height="38" Margin="0,0,8,8" Content="Open Signing Config" Click="OpenSigningConfig_Click" />
                <Button Height="38" Margin="0,0,8,8" Content="Open Publish Folder" Click="OpenNativePublishFolder_Click" />
                <Button Height="38" Margin="0,0,8,8" Content="Open Installer Folder" Click="OpenNativeInstallerFolder_Click" />
                <Button Height="38" Margin="0,0,8,8" Content="Open MSIX Folder" Click="OpenNativeMsixFolder_Click" />
                <Button Height="38" Margin="0,0,8,8" Content="Refresh" Click="RefreshReleaseData_Click" />
              </WrapPanel>
              </StackPanel>
              <Border Grid.Row="1" Background="#0D1826" CornerRadius="14" Padding="14" Margin="0,10,0,0">
                <DockPanel>
                  <TextBlock DockPanel.Dock="Top" Text="Product Status" FontSize="16" FontWeight="Bold" Foreground="{StaticResource TextFg}" />
                  <TextBox x:Name="ReleaseStatusBox"
                           Margin="0,10,0,0"
                           Background="#0D1826"
                           Foreground="{StaticResource TextFg}"
                           BorderThickness="0"
                           IsReadOnly="True"
                           AcceptsReturn="True"
                           TextWrapping="Wrap"
                           Text="Loading product status..." />
                </DockPanel>
              </Border>
              <TextBox x:Name="ReleaseDataBox"
                       Grid.Row="2"
                       Text="Loading release data..."
                       Background="#0D1826"
                       Foreground="{StaticResource TextFg}"
                       BorderThickness="0"
                       IsReadOnly="True"
                       AcceptsReturn="True"
                       Margin="0,8,0,0"
                       TextWrapping="Wrap" />
            </Grid>
          </Border>
        </TabItem>

        <TabItem Header="GitHub">
          <Border Margin="12" Background="{StaticResource PanelBg}" CornerRadius="16" Padding="16">
            <Grid>
              <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
              </Grid.RowDefinitions>
              <StackPanel>
              <TextBlock Text="GitHub" FontSize="18" FontWeight="Bold" Foreground="{StaticResource TextFg}" />
              <TextBlock Text="Simple GitHub-facing actions for sharing Zero OS."
                         Margin="0,6,0,16"
                         Foreground="{StaticResource MutedFg}" />
              <WrapPanel>
                <Button Height="38" Margin="0,0,8,8" Content="Open Repository" Click="OpenRepository_Click" />
                <Button Height="38" Margin="0,0,8,8" Content="Open Releases" Click="OpenReleases_Click" />
                <Button Height="38" Margin="0,0,8,8" Content="GitHub Status" Click="GithubStatus_Click" />
                <Button Height="38" Margin="0,0,8,8" Content="Refresh" Click="RefreshGithubData_Click" />
              </WrapPanel>
              </StackPanel>
              <TextBox x:Name="GithubDataBox"
                       Grid.Row="1"
                       Text="Loading GitHub data..."
                       Background="#0D1826"
                       Foreground="{StaticResource TextFg}"
                       BorderThickness="0"
                       IsReadOnly="True"
                       AcceptsReturn="True"
                       Margin="0,8,0,0"
                       TextWrapping="Wrap" />
            </Grid>
          </Border>
        </TabItem>

