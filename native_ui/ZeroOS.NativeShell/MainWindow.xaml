                <Button Height="38" Margin="0,0,8,8" Content="Zero AI Runtime Loop On" Click="ZeroAiRuntimeLoopOn_Click" />
                <Button Height="38" Margin="0,0,8,8" Content="Zero AI Runtime Loop Tick" Click="ZeroAiRuntimeLoopTick_Click" />
                <Button Height="38" Margin="0,0,8,8" Content="Zero AI Runtime Loop Off" Click="ZeroAiRuntimeLoopOff_Click" />
                <Button Height="38" Margin="0,0,8,8" Content="Install Background Agent" Click="ZeroAiRuntimeAgentInstall_Click" />
