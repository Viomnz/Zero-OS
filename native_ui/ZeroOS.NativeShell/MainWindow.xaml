                           Margin="0,12,0,0"
                           Background="#0D1826"
                           Foreground="{StaticResource TextFg}"
                           BorderThickness="0"
                           IsReadOnly="True"
                           AcceptsReturn="True"
                           VerticalScrollBarVisibility="Auto"
                           TextWrapping="Wrap"
                           Text="Loading Antivirus specs..." />
