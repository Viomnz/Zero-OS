{
  "version": 2,
  "schema": "zero-os-driver-manifest-v2",
  "compatibility": {
    "os": ["windows", "linux", "macos"],
    "runtime": "python>=3.11"
  },
  "lifecycle": ["probe", "init", "run", "suspend", "resume", "shutdown"],
  "health_checks": [
    "driver_loaded",
    "interface_contract_valid",
    "heartbeat_recent"
  ],
  "drivers": [
    {
      "name": "generic-fs",
      "group": "storage",
      "status": "active",
      "contract_version": "1.0"
    },
    {
      "name": "generic-net",
      "group": "network",
      "status": "active",
      "contract_version": "1.0"
    },
    {
      "name": "generic-display",
      "group": "display",
      "status": "planned",
      "contract_version": "1.0"
    }
  ]
}
